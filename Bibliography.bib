  langid = {english},
  keywords = {Agroecology,Biodiversity,Conservation biology,Ecosystem services},
  file = {C:\Users\suada\Zotero\storage\RW9Z7RJW\Dicks et al. - 2021 - A global-scale expert assessment of drivers and risks associated with pollinator decline.pdf}
}

